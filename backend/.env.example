APP_NAME=NexAlpha FastAPI
APP_BASE_URL=http://127.0.0.1:8000
API_BASE_URL=http://127.0.0.1:8000/api
DATABASE_URL=sqlite:///./backend/data/nexalpha.db
SECRET_KEY=replace-this-before-production
JWT_ALGORITHM=HS256
SESSION_COOKIE_NAME=nexalpha_session
SESSION_TTL_MINUTES=10080
SESSION_COOKIE_SECURE=false
VERIFICATION_TOKEN_TTL_HOURS=48
CORS_ORIGINS=http://127.0.0.1:8000

# Optional: bootstrap a first admin account on startup
BOOTSTRAP_ADMIN_EMAIL=admin@nexalpha.local
BOOTSTRAP_ADMIN_PASSWORD=change-me-now
BOOTSTRAP_ADMIN_NAME=NexAlpha Admin

# Optional: local development tools
ENABLE_DEV_TOOLS=false
DEV_ADMIN_TOKEN=change-this-dev-token

# Optional: SMTP email delivery. If omitted, registration returns a preview verification URL.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=NexAlpha

# Optional: Razorpay integration
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_PLAN_ID=
RAZORPAY_WEBHOOK_SECRET=
